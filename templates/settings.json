{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-cross-repo-writes.mjs\"",
            "timeout": 10,
            "statusMessage": "Checking write stays inside this repo…"
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-lane-authoring.mjs\"",
            "timeout": 10,
            "statusMessage": "Checking the task's lane declaration…"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-gate-ladder.mjs\"",
            "timeout": 10,
            "statusMessage": "Resolving the declared tier; surfacing the ladder it owes…"
          }
        ]
      }
    ]
  }
}
